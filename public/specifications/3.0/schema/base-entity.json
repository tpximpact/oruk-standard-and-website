{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openreferraluk.org/specifications/3.0/schema/base-entity.json",
  "title": "Base Entity",
  "description": "Common properties and structure for all entity schemas in HSDS-UK",
  "type": "object",
  "properties": {
    "id": {
      "description": "The unique identifier for this entity. Each entity must have a unique identifier.",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions.json#/$defs/uuid_id"
    },
    "name": {
      "description": "The name of the entity",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions.json#/$defs/name"
    },
    "description": {
      "description": "A free text description of this entity",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions.json#/$defs/description"
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": true
}