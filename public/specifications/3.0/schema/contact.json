{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openreferraluk.org/specifications/3.0/schema/contact.json",
  "name": "contact",
  "path": "contacts.csv",
  "description": "The details of the named contacts for services and organizations.",
  "datapackage_metadata": {
    "format": "csv",
    "mediatype": "text/csv",
    "profile": "tabular-data-resource",
    "order": 8
  },
  "type": "object",
  "properties": {
    "id": {
      "description": "The identifier for the contact. Each contact must have a unique identifier.",
      "example": "1e7efce3-639b-4880-940c-b95cd30cdb50",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions/id_property.json"
    },
    "service_id": {
      "description": "The identifier of the service for which this is a contact.",
      "example": "ac148810-d857-441c-9679-408f346de14b",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions/service_id_property.json"
    },
    "name": {
      "description": "The name of the contact.",
      "example": "Ann Persona",
      "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions/name_property.json"
    },
    "title": {
      "type": "string",
      "title": "Title",
      "description": "The job title of the contact.",
      "constraints": {
        "unique": false
      },
      "example": "Reception Manager"
    },
    "attributes": {
      "type": "array",
      "title": "Attributes",
      "description": "A link between a service and one or more classifications that describe the nature of the service provided.",
      "items": {
        "$ref": "https://openreferraluk.org/specifications/3.0/schema/attribute.json"
      }
    }
  },
  "required": [
    "id"
  ]
}
