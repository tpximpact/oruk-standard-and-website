{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Common Property Definitions",
  "description": "Reusable property definitions for Open Referral UK schemas",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "date": {
      "type": "string",
      "description": "Date in ISO 8601 format (YYYY-MM-DD)"
    },
    "datetime": {
      "type": "string",
      "format": "date-time",
      "description": "DateTime in ISO 8601 format with millisecond accuracy"
    },
    "id": {
      "name": "id",
      "type": "string",
      "title": "Identifier",
      "format": "uuid",
      "constraints": {
        "unique": true
      }
    },
    "name": {
      "name": "name",
      "type": "string",
      "title": "Name",
      "constraints": {
        "unique": false
      }
    },
    "description": {
      "name": "description",
      "type": "string",
      "title": "Description",
      "constraints": {
        "unique": false
      }
    },
    "attributes_array": {
      "name": "attributes",
      "type": "array",
      "title": "Attributes",
      "description": "A link between a service and one or more classifications that describe the nature of the service provided.",
      "items": {
        "$ref": "https://openreferraluk.org/specifications/3.0/schema/attribute.json"
      }
    },
    "constraints": {
      "unique_true": {
        "unique": true
      },
      "unique_false": {
        "unique": false
      }
    }
  }
}
