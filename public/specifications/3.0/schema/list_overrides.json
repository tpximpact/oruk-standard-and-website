{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "List Schema Overrides",
  "description": "Reusable property overrides for list/projection schemas.",
  "$defs": {
    "organization_list": {
      "properties": {
        "organization_identifiers": false,
        "attributes": false
      }
    },
    "service_list": {
      "properties": {
        "schedules": false,
        "service_areas": false,
        "service_at_locations": false,
        "languages": false,
        "funding": false,
        "cost_options": false,
        "contacts": false,
        "attributes": false
      }
    },
    "service_at_location_list": {
      "properties": {
        "service": {
          "$ref": "https://openreferraluk.org/specifications/3.0/schema/service_list.json"
        }
      }
    }
  }
}