{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openreferraluk.org/specifications/3.0/schema/definitions.json",
  "title": "Open Referral UK Common Definitions",
  "description": "A combined collection of common property definitions for the HSDS profile.",
  "$defs": {
    "date_string": {
      "$anchor": "date-field",
      "title": "Date",
      "type": "string",
      "format": "date"
    },
    "datetime_string": {
      "$anchor": "datetime-field",
      "title": "DateTime",
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "$anchor": "description-field",
      "title": "Description",
      "type": "string"
    },
    "email": {
      "$anchor": "email-field",
      "title": "Email",
      "type": "string",
      "format": "email"
    },
    "latitude": {
      "$anchor": "latitude-field",
      "title": "Latitude",
      "description": "The latitude expressed in decimal degrees in WGS84 datum.",
      "type": "number"
    },
    "longitude": {
      "$anchor": "longitude-field",
      "title": "Longitude",
      "description": "The longitude expressed in decimal degrees in WGS84 datum.",
      "type": "number"
    },
    "maximum_age": {
      "$anchor": "maximum-age-field",
      "title": "Maximum Age",
      "type": "number"
    },
    "minimum_age": {
      "$anchor": "minimum-age-field",
      "title": "Minimum Age",
      "type": "number"
    },
    "name": {
      "$anchor": "name-field",
      "title": "Name",
      "type": "string"
    },
    "uri": {
      "$anchor": "uri-field",
      "title": "URI",
      "type": "string",
      "format": "uri"
    },
    "url": {
      "$anchor": "url-field",
      "title": "URL",
      "type": "string",
      "format": "uri"
    },
    "uuid_id": {
      "$anchor": "uuid-id",
      "title": "Identifier",
      "type": "string",
      "format": "uuid",
      "x-constraints": {
        "unique": true
      }
    },
    "uuid_reference": {
      "$anchor": "uuid-reference",
      "title": "Identifier Reference",
      "type": "string",
      "format": "uuid"
    }
  }
}