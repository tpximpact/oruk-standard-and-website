{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shared Definitions for Open Referral UK",
  "description": "Reusable property and pattern definitions used across all schemas",
  "$defs": {
    "uuid_id": {
      "name": "id",
      "type": "string",
      "title": "Identifier",
      "format": "uuid",
      "constraints": {
        "unique": true
      }
    },
    "uuid_reference": {
      "type": "string",
      "format": "uuid",
      "constraints": {
        "unique": false
      }
    },
    "name": {
      "name": "name",
      "type": "string",
      "title": "Name",
      "constraints": {
        "unique": false
      }
    },
    "description": {
      "name": "description",
      "type": "string",
      "title": "Description",
      "constraints": {
        "unique": false
      }
    },
    "email": {
      "type": "string",
      "format": "email",
      "constraints": {
        "unique": false
      }
    },
    "uri": {
      "type": "string",
      "format": "uri",
      "constraints": {
        "unique": false
      }
    },
    "datapackage_metadata": {
      "format": "csv",
      "mediatype": "text/csv",
      "profile": "tabular-data-resource"
    },
    "service_status": {
      "type": "string",
      "title": "Status",
      "description": "The current status of the service.",
      "enum": [
        "active",
        "inactive",
        "defunct",
        "temporarily closed"
      ]
    }
  }
}
