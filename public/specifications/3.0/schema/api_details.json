{
  "name": "api_details",
  "description": "Information about this API and its relationship with HSDS",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "HSDS version of this API.",
      "example": "HSDS 3.0"
    },
    "profile": {
      "allOf": [
        {
          "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions.json#/$defs/uri"
        }
      ],
      "description": "URL of the information on the HSDS profile of this API.",
      "example": "https://github.com/OpenReferralUK/uk-profile/blob/main/docs/index.md"
    },
    "openapi_url": {
      "allOf": [
        {
          "$ref": "https://openreferraluk.org/specifications/3.0/schema/definitions.json#/$defs/uri"
        }
      ],
      "description": "URL of the openapi JSON file which defines this API.",
      "example": "https://docs.openreferraluk.org/en/latest/openapi30.json"
    }
  },
  "required": [
    "version",
    "profile",
    "openapi_url"
  ]
}