{
  "openapi": "3.0.0",
  "info": {
    "title": "Open Referral UK Profile",
    "version": "HSDS-UK-3.0",
    "summary": "Open Referral UK API for discovering health and social care services",
    "description": "This API specification defines the Open Referral UK Profile for version 3.0, providing standardized access to information about health, human, and social services available in communities.",
    "contact": {
      "name": "Open Referral UK",
      "url": "https://openreferraluk.org",
      "email": "info@openreferraluk.org"
    },
    "license": {
      "name": "Creative Commons Attribution Share-Alike 4.0 license",
      "url": "https://creativecommons.org/licenses/by/4.0/"
    }
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "tags": [
    {
      "name": "required",
      "description": "Required endpoints that must be implemented by all conformant services"
    },
    {
      "name": "optional",
      "description": "Optional endpoints that may not be implemented by all services"
    }
  ],
  "externalDocs": {
    "description": "Open Referral UK Schema Documentation",
    "url": "http://localhost:3000/specifications/3.0/"
  },
  "paths": {
