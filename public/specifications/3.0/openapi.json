                    {
                      "type": "object",
                      "properties": {
                        "contents": {
                          "type": "array",
                          "items": {
                            "$ref": "http://localhost:3000/specifications/3.0/schema/organization_list.json"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
